# ---- REQUIRED ----
# Random long string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Random 32-byte hex (64 chars). Used to encrypt WooCommerce keys at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-me-with-64-hex-characters

# Master admin email — auto-promoted to admin on first login.
ADMIN_EMAIL=contact@ultrax.work

# ---- OPTIONAL ----
PORT=3000
# Path to SQLite file. Relative paths are resolved from the server/ directory.
DB_PATH=./data/ultrax.db
# Comma-separated allowed origins for CORS. Use * for any (not recommended).
CORS_ORIGIN=https://www.ultrax.work,https://ultrax.work

# ---- AUTO-DEPLOY (GitHub webhook) ----
# Long random string. Set the SAME value in your GitHub repo:
#   Settings -> Webhooks -> Add webhook -> Secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_WEBHOOK_SECRET=replace-me-with-a-long-random-string
